#!/usr/bin/env python3
import os
import sys
import argparse

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from _lib import django_setup, fmt_time
django_setup()

from django.utils import timezone
from tracker.models import Project, Session, Event


def main():
    parser = argparse.ArgumentParser(description='Encerra sessão de trabalho')
    parser.add_argument('nickname', nargs='?', help='Apelido do projeto')
    parser.add_argument('--name', dest='nickname_flag', metavar='APELIDO', help='Apelido do projeto')
    parser.add_argument('--notes', default='', help='Notas sobre a sessão')
    args = parser.parse_args()

    nickname = args.nickname or args.nickname_flag
    if not nickname:
        print('❌  Informe o apelido: end-session <apelido>')
        sys.exit(1)

    print('⬡  DevTracker — encerrando sessão...')

    try:
        project = Project.objects.get(nickname=nickname)
    except Project.DoesNotExist:
        print(f'❌  Projeto "{nickname}" não encontrado')
        sys.exit(1)

    session = Session.objects.filter(project=project, ended_at__isnull=True).first()
    if not session:
        print(f'❌  Nenhuma sessão ativa para "{project.name}"')
        sys.exit(1)

    session.ended_at = timezone.now()
    if args.notes:
        session.notes = args.notes
    session.save()
    Event.objects.create(session=session, event_type='session_end')

    start = session.started_at.strftime('%H:%M')
    end = session.ended_at.strftime('%H:%M')
    total = fmt_time(session.total_seconds)
    total_proj = fmt_time(project.total_seconds)

    print()
    print('━' * 38)
    print(f'✅  Sessão encerrada — {project.name}')
    print('━' * 38)
    print(f'🕐  Horário:     {start} → {end}  ({total})')
    print(f'📊  Total acum.: {total_proj}')
    print('━' * 38)


if __name__ == '__main__':
    main()
