#!/usr/bin/env python3
import os
import re
import sys
import argparse

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from _lib import django_setup, open_pycharm
django_setup()

from django.utils.text import slugify
from tracker.models import Project


def unique_slug(name):
    base = slugify(name)
    slug = base
    counter = 1
    while Project.objects.filter(slug=slug).exists():
        slug = f'{base}-{counter}'
        counter += 1
    return slug


def default_nickname(name):
    return re.sub(r'[^a-z0-9]+', '-', name.lower()).strip('-')


def main():
    parser = argparse.ArgumentParser(description='Cadastra novo projeto no DevTracker')
    parser.add_argument('--name', help='Nome do projeto (pode conter espaços)')
    parser.add_argument('--nickname', help='Apelido único, sem espaços (usado nos comandos)')
    parser.add_argument('--dir', dest='directory', help='Diretório do projeto')
    args = parser.parse_args()

    interactive = not any([args.name, args.nickname, args.directory])

    if interactive:
        print('⬡  DevTracker — novo projeto')
        print()

        name = input('Nome do projeto: ').strip()
        if not name:
            print('❌  Nome é obrigatório')
            sys.exit(1)

        nick_default = default_nickname(name)
        while True:
            try:
                import readline
                readline.set_pre_input_hook(lambda: (readline.insert_text(nick_default), readline.redisplay()))
                nickname = input('Apelido: ').strip()
                readline.set_pre_input_hook(None)
            except ImportError:
                nickname = input(f'Apelido [{nick_default}]: ').strip()
            nickname = nickname or nick_default
            if not re.match(r'^[a-zA-Z0-9_-]+$', nickname):
                print('❌  Apelido não pode conter espaços ou caracteres especiais')
                nick_default = nickname
                continue
            if Project.objects.filter(nickname=nickname).exists():
                existing = Project.objects.get(nickname=nickname)
                print(f'⚠️   Apelido "{nickname}" já existe: {existing.name}')
                nick_default = nickname
                continue
            break

        current = os.getcwd()
        try:
            import readline
            readline.set_pre_input_hook(lambda: (readline.insert_text(current), readline.redisplay()))
            entered = input('Diretório: ').strip()
            readline.set_pre_input_hook(None)
        except ImportError:
            entered = input(f'Diretório [{current}]: ').strip()
        directory = os.path.expanduser(entered) if entered else current

    else:
        print('⬡  DevTracker — cadastrando projeto...')

        name = args.name
        nickname = args.nickname or (default_nickname(args.name) if args.name else None)
        directory = os.path.expanduser(args.directory) if args.directory else os.getcwd()

        if not name:
            print('❌  --name é obrigatório')
            sys.exit(1)
        if not nickname:
            print('❌  --nickname é obrigatório')
            sys.exit(1)

    if not re.match(r'^[a-zA-Z0-9_-]+$', nickname):
        print('❌  Apelido não pode conter espaços ou caracteres especiais')
        sys.exit(1)

    if Project.objects.filter(nickname=nickname).exists():
        existing = Project.objects.get(nickname=nickname)
        print(f'⚠️   Apelido "{nickname}" já existe: {existing.name}')
        sys.exit(1)

    directory = os.path.expanduser(directory)

    project = Project.objects.create(
        name=name,
        slug=unique_slug(name),
        nickname=nickname,
        path=directory,
    )

    print(f'✅  Projeto criado: {project.name}')
    print(f'   Apelido:   {project.nickname}')
    print(f'   Diretório: {directory}')

    if not open_pycharm(directory):
        print(f'⚠️   PyCharm não encontrado. Abra manualmente: {directory}')


if __name__ == '__main__':
    main()
