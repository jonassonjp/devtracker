#!/usr/bin/env bash
DEVTRACKER_DIR="${DEVTRACKER_DIR:-$HOME/workspace/devtracker}"
VENV_DIR="$DEVTRACKER_DIR/.venv"
PORT=7000

[ ! -f "$VENV_DIR/bin/python" ] && echo "❌  Execute ./install.sh primeiro." && exit 1

echo "⬡  DevTracker — http://localhost:$PORT  (Ctrl+C para encerrar)"
echo ""

(sleep 1 && xdg-open "http://localhost:$PORT" 2>/dev/null) &

cd "$DEVTRACKER_DIR"
"$VENV_DIR/bin/python" manage.py runserver "127.0.0.1:$PORT"
